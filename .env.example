POSTGRES_DB=dental_bot
POSTGRES_USER=dental
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=55432
DATABASE_URL=postgresql+psycopg://dental:change-me@postgres:5432/dental_bot

REDIS_URL=redis://redis:6379/0
REDIS_PORT=6380
NATS_URL=nats://nats:4222
NATS_PORT=4224
NATS_MONITOR_PORT=8224

CORE_API_URL=http://core-api:8000
CORE_API_PORT=8100
AI_ORCHESTRATOR_URL=http://ai-orchestrator:8001
AI_ORCHESTRATOR_PORT=8101
CRM_MOCK_URL=http://crm-mock:8002
CRM_MOCK_PORT=8102
BOT_GATEWAY_PORT=8180

TELEGRAM_BOT_TOKEN=
# polling — локально без публичного URL; webhook — production
TELEGRAM_MODE=polling
# Прокси v2rayA/clash для api.telegram.org (проверка: curl -x http://127.0.0.1:20170 https://api.telegram.org)
TELEGRAM_PROXY_URL=http://127.0.0.1:20170
# ngrok: ngrok http 8180
TELEGRAM_WEBHOOK_URL=https://your-public-url.example.com/api/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=change-me-to-random-value
TELEGRAM_API_BASE=https://api.telegram.org

STAFF_GROUP_CHAT_ID=
DOCTOR_TELEGRAM_IDS=
STAFF_TELEGRAM_IDS=
CLINIC_PHONE=+79990000000

AI_MODE=rules
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

CRM_MOCK_FAILURE_RATE=0
LOG_LEVEL=INFO

ADMIN_TOKEN=change-me-admin-token
ADMIN_PORT=8190
BOT_GATEWAY_URL=http://127.0.0.1:8180

# Общий токен для bot-gateway / worker / ai -> core-api (и ai intake)
INTERNAL_SERVICE_TOKEN=change-me-internal-token

# Локальная разработка: включить simulate для demo-run (production: false)
DEBUG_API_ENABLED=false
DEBUG_API_TOKEN=
